.#-------------------------------------------------------------------------------------------------------
.inputexpect|blocknote/1.0
.# Test link custom parameters are preserved.
.#-------------------------------------------------------------------------------------------------------
[ {
  "type" : "paragraph",
  "props" : { },
  "content" : [ {
    "type" : "link",
    "props" : {
      "xwikiParameters" : {
        "data-foo" : "bar",
        "rel" : "nofollow"
      },
      "xwikiReference" : {
        "reference" : "http://xwiki.org",
        "type" : {
          "scheme" : "url"
        },
        "typed" : false,
        "parameters" : { }
      }
    },
    "content" : "label",
    "href" : "http://xwiki.org"
  } ]
} ]
.#-----------------------------------------------------
.expect|xwiki/2.1
.#-----------------------------------------------------
[[label>>http://xwiki.org||data-foo="bar" rel="nofollow"]]