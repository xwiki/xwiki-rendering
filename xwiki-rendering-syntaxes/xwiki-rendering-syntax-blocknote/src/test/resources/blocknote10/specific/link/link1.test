.#-------------------------------------------------------------------------------------------------------
.inputexpect|blocknote/1.0
.# Test that the link href is computed using the WikiModel / RenderingConfiguration components,
.# depending on the resource reference type (attachment, document, mailto, UNC, interwiki).
.#-------------------------------------------------------------------------------------------------------
[ {
  "type" : "paragraph",
  "props" : { },
  "content" : [ {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "/path/to/file",
        "type" : {
          "scheme" : "path"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "/path/to/file"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "Space.Page@file.pdf",
        "type" : {
          "scheme" : "attach"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "attachmenturl"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "Space.ExistingPage",
        "type" : {
          "scheme" : "doc"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "viewurl"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "Space.NonExistingPage",
        "type" : {
          "scheme" : "doc"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "editurl"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "ExistingPage",
        "type" : {
          "scheme" : "page"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "viewurl"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "",
        "type" : {
          "scheme" : "doc"
        },
        "typed" : true,
        "parameters" : {
          "queryString" : "param1=value1&param2=value2",
          "anchor" : "foo"
        }
      }
    },
    "content" : [ ],
    "href" : "?param1=value1&param2=value2#foo"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "ExistingSpace",
        "type" : {
          "scheme" : "space"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "viewurl"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "jane@example.com",
        "type" : {
          "scheme" : "mailto"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "mailto:jane@example.com"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "home\\user\\file.txt",
        "type" : {
          "scheme" : "unc"
        },
        "typed" : true,
        "parameters" : { }
      }
    },
    "content" : [ ],
    "href" : "file:///home/user/file.txt"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "XWiki",
        "type" : {
          "scheme" : "interwiki"
        },
        "typed" : true,
        "parameters" : {
          "interWikiAlias" : "wikipedia"
        }
      }
    },
    "content" : [ ],
    "href" : "http://en.wikipedia.org/wiki/XWiki"
  }, {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "SomePage",
        "type" : {
          "scheme" : "interwiki"
        },
        "typed" : true,
        "parameters" : {
          "interWikiAlias" : "unknownalias"
        }
      }
    },
    "content" : [ ],
    "href" : "SomePage"
  } ]
} ]
.#-----------------------------------------------------
.expect|xwiki/2.1
.#-----------------------------------------------------
[[path:/path/to/file]][[attach:Space.Page@file.pdf]][[doc:Space.ExistingPage]][[doc:Space.NonExistingPage]][[page:ExistingPage]][[doc:||queryString="param1=value1&param2=value2" anchor="foo"]][[space:ExistingSpace]][[mailto:jane@example.com]][[unc:home\user\file.txt]][[interwiki:wikipedia:XWiki]][[interwiki:unknownalias:SomePage]]