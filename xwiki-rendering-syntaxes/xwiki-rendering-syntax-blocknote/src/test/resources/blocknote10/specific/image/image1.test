.# Test all image properties.
.#-------------------------------------------------------------------------------------------------------
[ {
  "type" : "paragraph",
  "props" : { },
  "content" : [ "Some ", {
    "type" : "image",
    "props" : {
      "textAlignment" : "center",
      "name" : "alternative text",
      "xwikiReference" : {
        "reference" : "image.png",
        "type" : "url",
        "typed" : false,
        "parameters" : { }
      },
      "url" : "image.png",
      "previewWidth" : 250,
      "caption" : "This is the caption"
    }
  } ]
}, {
  "type" : "image",
  "props" : {
    "textAlignment" : "right",
    "name" : "my logo",
    "xwikiReference" : {
      "reference" : "logo.png",
      "type" : "url",
      "typed" : false,
      "parameters" : { }
    },
    "url" : "logo.png",
    "previewWidth" : 100,
    "caption" : "Caption for my logo"
  }
} ]
