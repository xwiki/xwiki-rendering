.# Test linked image support.
.#-------------------------------------------------------------------------------------------------------
[ {
  "type" : "paragraph",
  "props" : { },
  "content" : [ {
    "type" : "link",
    "props" : {
      "xwikiReference" : {
        "reference" : "https://xwiki.org",
        "type" : "url",
        "typed" : false,
        "parameters" : { }
      }
    },
    "content" : [ {
      "type" : "image",
      "props" : {
        "textAlignment" : "center",
        "name" : "alternative text",
        "xwikiReference" : {
          "reference" : "image.png",
          "type" : "url",
          "typed" : false,
          "parameters" : { }
        },
        "url" : "image.png",
        "previewWidth" : 250,
        "caption" : "This is the caption"
      }
    } ],
    "href" : "https://xwiki.org"
  } ]
} ]
.#-----------------------------------------------------
.expect|xwiki/2.1
