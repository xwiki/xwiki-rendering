.#-------------------------------------------------------------------------------------------------------
.inputexpect|blocknote/1.0
.# Test paragraph styles.
.#-------------------------------------------------------------------------------------------------------
[ {
  "type" : "paragraph",
  "props" : {
    "textColor" : "red",
    "backgroundColor" : "yellow",
    "textAlignment" : "justify",
    "xwiki:parameters" : {
      "style" : "padding: 6px"
    }
  },
  "content" : [ "Some ", {
    "type" : "text",
    "styles" : {
      "textColor" : "green",
      "backgroundColor" : "blue",
      "xwiki:parameters" : {
        "style" : "text-transform: uppercase"
      },
      "code" : true,
      "strike" : true,
      "underline" : true,
      "italic" : true,
      "bold" : true
    },
    "text" : "styled"
  }, " text." ]
} ]
.#-----------------------------------------------------
.expect|xwiki/2.1
.#-----------------------------------------------------
(% style="padding: 6px;color:red;background-color:yellow;text-align:justify" %)
Some (% style="text-transform: uppercase;color:green;background-color:blue" %)**//__--##styled##--__//**(%%) text.