.# Test paragraph styles.
.#-------------------------------------------------------------------------------------------------------
[ {
  "type" : "paragraph",
  "props" : {
    "textColor" : "red",
    "backgroundColor" : "yellow",
    "textAlignment" : "justify"
  },
  "content" : [ "Some ", {
    "type" : "text",
    "styles" : {
      "textColor" : "green",
      "backgroundColor" : "blue",
      "code" : true,
      "strike" : true,
      "underline" : true,
      "italic" : true,
      "bold" : true
    },
    "text" : "styled"
  }, " text." ]
} ]
