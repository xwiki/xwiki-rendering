    "content" : "line2",
    "children" : [ ]
  }, {
    "type" : "quote",
    "props" : { },
    "content" : "lineTwo",
    "children" : [ {
      "type" : "quote",
      "props" : { },
      "content" : "line3",
      "children" : [ ]
    }, {
      "type" : "quote",
      "props" : { },
      "content" : "lineThree",
      "children" : [ ]
    } ]
  }, {
    "type" : "quote",
    "props" : { },
    "content" : "line4",
    "children" : [ ]
  }, {
    "type" : "quote",
    "props" : { },
    "content" : "lineFour",
    "children" : [ ]
  } ]
}, {
  "type" : "paragraph",
  "props" : { },
  "content" : "after"
