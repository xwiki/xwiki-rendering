.#-------------------------------------------------------------------------
.input|xhtml/1.0
.# Verify that empty lines before and after a macro without non-generated
.# content (i.e. no editable parameters or content) are preserved as
.# onEmptyLines events at the document level. See also emptyline2.test for
.# the case where the macro has non-generated content (editable parameters
.# or content rendered in-place).
.#-------------------------------------------------------------------------
<h1>Foo</h1>
<div class="wikimodel-emptyline"></div>
<!--startmacro:toc|-|--><!--stopmacro-->
<div class="wikimodel-emptyline"></div>
<h2>Bar</h2>
.#-----------------------------------------------------
.expect|event/1.0
.#-----------------------------------------------------
beginDocument
beginSection
beginHeader [1, HFoo]
onWord [Foo]
endHeader [1, HFoo]
onEmptyLines [1]
onMacroStandalone [toc] []
onEmptyLines [1]
beginSection
beginHeader [2, HBar]
onWord [Bar]
endHeader [2, HBar]
endSection
endSection
endDocument